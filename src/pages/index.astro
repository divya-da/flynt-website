/* ── Who It's For scroll animations ── */
@keyframes audienceCardIn {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}

.audience-card {
  opacity: 0;
}

.audience-card.visible {
  animation: audienceCardIn 0.65s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}

.audience-card--s1.visible { animation-delay: 0s; }
.audience-card--s2.visible { animation-delay: 0.12s; }
.audience-card--s3.visible { animation-delay: 0.24s; }
.audience-card--s4.visible { animation-delay: 0.36s; }

@media (prefers-reduced-motion: reduce) {
  .audience-card { opacity: 1; }
  .audience-card.visible { animation: none; }
