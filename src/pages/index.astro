<script is:inline>
  // ── Hero play button ──
  (function () {
    var video = document.getElementById('heroVideo');
    var btn = document.getElementById('heroPlayBtn');
    if (!video || !btn) return;
    btn.addEventListener('click', function () {
      video.play();
      btn.classList.add('hidden');
    });
    video.addEventListener('play', function () {
      btn.classList.add('hidden');
    });
    video.addEventListener('pause', function () {
      btn.classList.remove('hidden');
    });
  })();

  (function () {
    const section = document.querySelector('.built-for--grey');
    const img = section && section.querySelector('.audience-image img');

    // Parallax: centered on section midpoint, capped at ±50px
    function onScroll() {
      if (!img || !section) return;
      const rect = section.getBoundingClientRect();
      const offset = -rect.top * 0.13;
      img.style.transform = 'scale(1.15) translateY(' + offset + 'px)';
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Card stagger on scroll into view
    const cards = document.querySelectorAll('.audience-card');
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    cards.forEach(function(card) { observer.observe(card); });
  })();

  // ── How It Works: Group.svg parallax ──
  (function () {
    var svg = document.querySelector('.hiw-bg__svg');
    var section = document.querySelector('.how-it-works');
    if (!svg || !section) return;
    function onScroll() {
      var rect = section.getBoundingClientRect();
      var progress = Math.max(0, Math.min(1, -rect.top / Math.max(1, rect.height - window.innerHeight)));
      var y = (progress - 0.5) * 120;
      var rotate = progress * 12;
      svg.style.transform = 'translate(-50%, calc(-50% + ' + y + 'px)) rotate(' + rotate + 'deg)';
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();

  // ── How It Works: sticky split scroll ──
  (function () {
    var steps = document.querySelectorAll('.hiw-step');
    var imgs  = document.querySelectorAll('.hiw-img');
    var dots  = document.querySelectorAll('.hiw-dot');
    var current = '1';

    function playVideo(vid) {
      if (!vid) return;
      vid.currentTime = 0;
      var p = vid.play();
      if (p && p.catch) p.catch(function(){});
    }

    function activate(stepNum) {
      if (stepNum === current) return;
      current = stepNum;
      steps.forEach(function(s) { s.classList.toggle('hiw-step--active', s.dataset.step === stepNum); });
      imgs.forEach(function(img) {
        var isActive = img.dataset.step === stepNum;
        img.classList.toggle('hiw-img--active', isActive);
        if (img.tagName === 'VIDEO') {
          if (isActive) {
            img.currentTime = 0;
            var p = img.play(); if (p && p.catch) p.catch(function(){});
          } else {
            img.pause();
            img.currentTime = 0;
          }
        }
      });
      dots.forEach(function(d) { d.classList.toggle('hiw-dot--active', d.dataset.step === stepNum); });
    }

    // On scroll: activate whichever step center is closest to viewport center
    function onScroll() {
      var centerY = window.innerHeight / 2;
      var closest = null;
      var closestDist = Infinity;
      steps.forEach(function(step) {
        var rect = step.getBoundingClientRect();
        var stepCenter = rect.top + rect.height / 2;
        var dist = Math.abs(stepCenter - centerY);
        if (dist < closestDist) { closestDist = dist; closest = step; }
      });
      if (closest) activate(closest.dataset.step);
    }

    // Play step-1 video as soon as the HIW section enters the viewport
    var hiwSection = document.querySelector('.how-it-works');
    if (hiwSection && 'IntersectionObserver' in window) {
      var sectionObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting && current === null) {
            var firstVid = document.querySelector('.hiw-img[data-step="1"]');
            if (firstVid && firstVid.tagName === 'VIDEO') playVideo(firstVid);
          }
        });
      }, { threshold: 0.1 });
      sectionObserver.observe(hiwSection);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Dot click
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        var stepEl = document.querySelector('.hiw-step[data-step="' + dot.dataset.step + '"]');
        if (stepEl) stepEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    });
  })();
</script>
