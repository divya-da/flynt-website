---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Flynt AI — Client Acquisition Intelligence for Recruiters & Sales Teams"
  description="Flynt identifies who needs you before they know they need you. The AI intelligence layer built exclusively for client acquisition."
>

<!-- ─────────────────────────────────────────────
  SECTION 01 — HERO
───────────────────────────────────────────── -->
<section class="hero">
  <div class="container">
    <div class="hero__grid">
      <div class="hero__content">
        <div class="tag fade-up fade-up-1">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.09 6.26H21l-5.47 3.97 2.09 6.26L12 14.52l-5.62 3.97 2.09-6.26L3 8.26h6.91z"/></svg>
          Client Acquisition Intelligence
        </div>
        <h1 class="hero__headline fade-up fade-up-2">
          Intelligence Engine for<br />
          <span class="hero__headline-accent">Client Acquisition</span>
        </h1>
        <p class="hero__sub fade-up fade-up-3">
          Flynt continuously surfaces structured, signal-driven client opportunities for recruiters, sales teams, and GTM operators — so your team spends time closing new business, not buried in research.
        </p>
        <div class="hero__ctas fade-up fade-up-4">
          <a href="https://tryflynt.ai/" class="btn btn--primary btn--lg">Get Started</a>
          <a href="#how-it-works" class="btn btn--outline btn--lg">See How Flynt Works →</a>
        </div>
        <p class="hero__social-proof fade-up fade-up-4">
          Trusted by recruiters, agency operators, and GTM teams.
        </p>
      </div>
      <div class="hero__visual fade-up fade-up-3">
        <div class="hero__visual-glow"></div>
        <img
          src="/images/screenshots/run%20history%20zoomed.png"
          alt="Flynt Job Run History dashboard"
          class="hero__screenshot-img"
        />
      </div>
    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────
  SECTION 02 — HOW IT WORKS (dark background)
───────────────────────────────────────────── -->
<section class="positioning" id="how-it-works">
  <div class="container">
    <div class="section-header section-header--center positioning__header">
      <div class="tag positioning__tag">How It Works</div>
      <h2>Set it up once. Let it run.</h2>
    </div>
    <div class="steps">
      <div class="step">
        <div class="step__number">01</div>
        <h3>Define Your Targets</h3>
        <p>Industries, company size, job titles, geography. One-time setup — Flynt aligns to your criteria, not just keywords.</p>
      </div>
      <div class="step__connector"></div>
      <div class="step">
        <div class="step__number">02</div>
        <h3>Research Runs Automatically</h3>
        <p>AI agents work in the background. No list building, no spreadsheet juggling, no manual research sessions.</p>
      </div>
      <div class="step__connector"></div>
      <div class="step">
        <div class="step__number">03</div>
        <h3>Leads Land in Your Inbox</h3>
        <p>Every morning: names, titles, emails, and phone numbers — organised and ready to contact.</p>
      </div>
    </div>
  </div>
</section>



<!-- ─────────────────────────────────────────────
  SECTION 05 — WHO FLYNT IS BUILT FOR
───────────────────────────────────────────── -->
<section class="section built-for">
  <div class="container">
    <div class="section-header section-header--center">
      <div class="tag">Who It's For</div>
      <h2>Built for teams that own revenue.</h2>
    </div>

    <div class="audience-grid">
      <div class="audience-card">
        <div class="audience-card__icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <h3>Recruiters & Recruitment Agencies</h3>
        <p>Find the companies that need your services — before your competition does.</p>
      </div>

      <div class="audience-card">
        <div class="audience-card__icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
        </div>
        <h3>Sales & Go-to-Market Teams</h3>
        <p>The right accounts, at the right moment, with context — before every outreach.</p>
      </div>

      <div class="audience-card">
        <div class="audience-card__icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        </div>
        <h3>Agency Owners & Operators</h3>
        <p>Consistent client pipeline — without adding headcount or rebuilding lists.</p>
      </div>

      <div class="audience-card">
        <div class="audience-card__icon">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        </div>
        <h3>Revenue Leaders</h3>
        <p>Replace reactive prospecting with a system that runs whether your team is busy or not.</p>
      </div>
    </div>

    <p class="audience-qualifier">
      If your job depends on finding and winning new clients — Flynt is built for you.
    </p>
  </div>
</section>

<!-- ─────────────────────────────────────────────
  SECTION 06 — WHO FLYNT IS NOT FOR
───────────────────────────────────────────── -->
<section class="section section--gray not-for">
  <div class="container">
    <div class="not-for__layout">
      <div class="not-for__left">
        <div class="tag">Honest by design</div>
        <h2>Flynt is not for everyone.<br /><span style="color: var(--slate-500)">That's intentional.</span></h2>
        <p>Flynt is built to strengthen disciplined operators — not to replace the judgment, strategy, and execution that revenue work requires.</p>
        <blockquote class="not-for__quote">
          Flynt prepares opportunity. Your team converts it. The best results come from operators who understand the difference — and show up to execute.
        </blockquote>
      </div>
      <div class="not-for__right">
        <ul class="not-for__list">
          <li>
            <span class="not-for__icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </span>
            <span>Recruiters looking to source candidates or build talent pipelines — Flynt is for client acquisition, not candidate research</span>
          </li>
          <li>
            <span class="not-for__icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </span>
            <span>Teams expecting guaranteed clients, guaranteed revenue, or instant results</span>
          </li>
          <li>
            <span class="not-for__icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </span>
            <span>Operators unwilling to follow up consistently or refine their client targeting over time</span>
          </li>
          <li>
            <span class="not-for__icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </span>
            <span>Anyone looking for AI to replace the skill of selling, positioning, or relationship-building</span>
          </li>
          <li>
            <span class="not-for__icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </span>
            <span>Users who want a fully automated system that removes human judgment from the client acquisition process</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────
  SECTION 10 — FINAL CTA
───────────────────────────────────────────── -->
<section class="final-cta">
  <div class="container">
    <div class="final-cta__inner">
      <h2>Stop researching.<br />Start closing.</h2>
      <p>Your next client is already in the market. Flynt finds the signal before they find someone else.</p>
      <a href="https://tryflynt.ai/" class="btn btn--primary btn--lg">Get Started →</a>
      <span class="final-cta__disclaimer">No credit card required. Cancel anytime.</span>
    </div>
  </div>
</section>

</Layout>

<style>
/* ── Hero ── */
.hero {
  padding: 140px 0 240px;
  background: transparent;
  overflow: hidden;
}

.hero__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}

.hero__headline {
  font-size: 3rem;
  margin: 16px 0 28px;
  color: var(--black);
}

.hero__headline .hero__headline-accent {
  -webkit-text-stroke: 0.6px var(--purple);
}

.hero__headline-accent {
  color: var(--purple);
  display: block;
}

.hero__sub {
  font-size: 1.1rem;
  margin-bottom: 36px;
  color: var(--slate-600);
  line-height: 1.7;
}

.hero__ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}

.hero__social-proof {
  font-size: 0.875rem;
  color: var(--slate-500);
}

.hero__visual {
  position: relative;
}

.hero__visual-glow {
  position: absolute;
  inset: -24px;
  background: rgba(167, 139, 250, 0.35);
  border-radius: 28px;
  filter: blur(40px);
  z-index: 0;
  pointer-events: none;
}

.hero__screenshot-img {
  position: relative;
  z-index: 1;
  width: 100%;
  border-radius: 12px;
  box-shadow:
    0 2px 8px rgba(139, 92, 246, 0.08),
    0 12px 32px rgba(139, 92, 246, 0.14),
    0 40px 60px rgba(0, 0, 0, 0.18);
}

/* ── Positioning Strip ── */
.positioning {
  position: relative;
  background-color: #2B1F50;
  background-image: url('/images/backgrounds/World-Map.svg'), url('/images/backgrounds/purple-gradient-background.png');
  background-size: 45%, cover;
  background-position: right top, center;
  background-repeat: no-repeat, no-repeat;
  padding: 200px 24px 112px;
  clip-path: polygon(0 120px, 100% 0, 100% 100%, 0 100%);
  margin-top: -120px;
  z-index: 1;
  overflow: hidden;
}

.positioning .container {
  display: flex;
  flex-direction: column;
  gap: 48px;
  position: relative;
  z-index: 2;
}

.positioning__header h2 {
  color: #ffffff;
  -webkit-text-stroke: 0.6px #ffffff;
}

.positioning__header p {
  color: var(--purple-200);
}

.positioning__tag {
  background: rgba(255,255,255,0.12);
  color: #ffffff;
}

.positioning .step {
  background: rgba(255, 255, 255, 0.07);
  border: 1px solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  box-shadow: none;
}

.positioning .step__number {
  color: var(--purple-300);
  opacity: 1;
}

.positioning .step h3 {
  color: #ffffff;
  -webkit-text-stroke: 0.6px #ffffff;
}

.positioning .step p {
  color: var(--purple-200);
}

.positioning .step__connector {
  background: rgba(255,255,255,0.2);
}

/* ── What Flynt Does ── */
.what-flynt-does {
  padding: 160px 48px;
}
.what__tag-row {
  display: flex;
  justify-content: center;
  margin-bottom: 56px;
}

.what__tag {
  display: flex;
  align-items: center;
  gap: 6px;
}

.what__layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 72px;
  align-items: start;
}

.what__headline {
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 800;
  line-height: 1.3;
  letter-spacing: -0.03em;
  margin: 0 0 28px;
  color: var(--black);
  -webkit-text-stroke: 0.6px var(--black);
}

.what__headline-accent {
  color: var(--purple);
}

.what__clarity {
  margin: 0 0 24px;
  padding: 24px;
  background: var(--purple-bg);
  border-left: 4px solid var(--purple);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 1.125rem;
  font-weight: 500;
  color: var(--purple-900);
  line-height: 1.625;
}

.what__body {
  color: var(--slate-700);
  line-height: 1.7;
  margin-bottom: 16px;
}

.capability-card {
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-xl);
}

.capability-card__title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--slate-900);
  padding: 28px 28px 20px;
  margin: 0;
}

.capability-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0 28px;
}

.capability-list li {
  display: flex;
  gap: 16px;
  color: var(--slate-700);
  align-items: flex-start;
  line-height: 1.55;
  padding: 20px 0;
  border-top: 1px solid var(--gray-100);
}

.capability-list li:first-child {
  border-top: none;
}

.capability-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--purple-bg-2);
  color: var(--purple);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}

.capability-card__footer {
  border-top: 1px solid var(--slate-200);
  padding: 20px 28px 24px;
  margin-top: 8px;
}

.what__closing {
  font-size: 0.875rem;
  color: var(--slate-500);
  font-style: italic;
  line-height: 1.65;
  margin: 0;
}

/* ── How It Works ── */
.steps {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr;
  gap: 0;
  align-items: start;
}

.step {
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-lg);
  padding: 32px;
  box-shadow: var(--shadow-xl);
}

.step__number {
  font-family: var(--font-display);
  font-size: 2.5rem;
  font-weight: 800;
  color: var(--purple);
  opacity: 0.25;
  line-height: 1;
  margin-bottom: 16px;
}

.step h3 {
  margin-bottom: 12px;
  font-size: 1.1rem;
}

.step p {
  font-size: 0.9rem;
  color: var(--slate-600);
}

.step__connector {
  width: 40px;
  height: 1px;
  background: var(--slate-200);
  margin-top: 56px;
}

/* ── Audience ── */
.audience-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 32px;
}

.audience-card {
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-lg);
  padding: 28px;
  box-shadow: var(--shadow-xl);
  transition: background-color 0.2s, border-color 0.2s;
}

.audience-card:hover {
  background-color: var(--purple-bg);
  border-color: var(--purple-bg-2);
}

.audience-card:hover .audience-card__icon {
  background: var(--purple);
  color: white;
}

.audience-card__icon {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-sm);
  background: var(--purple-bg-2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--purple);
  margin-bottom: 16px;
  transition: background 0.2s, color 0.2s;
}

.audience-card h3 {
  font-size: 1rem;
  margin-bottom: 10px;
}

.audience-card p {
  font-size: 0.9rem;
  color: var(--slate-700);
}

.audience-qualifier {
  text-align: center;
  font-size: 0.95rem;
  color: var(--slate-600);
  padding: 20px 32px;
  background: var(--purple-bg);
  border-radius: var(--radius-md);
  border: 1px solid var(--purple-bg-2);
}

/* ── Not For ── */
.not-for__layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 72px;
  align-items: start;
}

.not-for__left h2 {
  margin: 12px 0 16px;
}

.not-for__quote {
  margin-top: 24px;
  font-style: italic;
  border-left: 4px solid var(--purple);
  padding: 20px 20px 20px 24px;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  background: var(--purple-bg);
  color: var(--purple-900);
  font-size: 1.125rem;
  line-height: 1.625;
}

.not-for__list-label {
  font-weight: 600;
  color: var(--slate-700);
  margin-bottom: 16px;
  font-size: 0.9rem;
}

.not-for__list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.not-for__list li {
  display: flex;
  gap: 16px;
  align-items: center;
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: 12px;
  padding: 20px 24px;
  box-shadow: 0 2px 8px rgba(139, 92, 246, 0.06), 0 1px 3px rgba(0,0,0,0.04);
  color: var(--slate-700);
}

.not-for__icon {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--purple-bg-2);
  color: var(--purple);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ── Final CTA ── */
.final-cta {
  position: relative;
  background-color: var(--white);
  background-image: url('/images/backgrounds/World-Map.svg');
  background-repeat: no-repeat;
  background-position: center;
  background-size: 70%;
  padding: 96px 24px;
}

.final-cta__inner {
  max-width: var(--max-width);
  margin: 0 auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

.final-cta__inner h2 {
  color: var(--black);
  font-size: clamp(2rem, 4vw, 3.2rem);
}

.final-cta__inner p {
  color: var(--slate-600);
  font-size: 1.125rem;
  max-width: 480px;
  line-height: 1.625;
}

.final-cta__disclaimer {
  font-size: 0.875rem;
  color: var(--slate-500);
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .hero { padding: 80px 0 100px; }
  .hero__grid { grid-template-columns: 1fr; gap: 48px; }
  .hero__headline { font-size: 2.25rem; }
  .hero__visual { order: -1; }
  .positioning__grid { grid-template-columns: 1fr; }
  .what__layout { grid-template-columns: 1fr; gap: 40px; }
  .what__tag-row { margin-bottom: 40px; }
  .steps {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .step__connector { display: none; }
  .audience-grid { grid-template-columns: 1fr; }
  .not-for__layout { grid-template-columns: 1fr; gap: 40px; }
}
</style>
