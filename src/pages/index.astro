---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Flynt AI — Intelligence Engine for Client Acquisition"
  description="Flynt’s AI Agents remove the manual research layer behind client acquisition — allowing you to focus on conversations that close."
>

<!-- ─────────────────────────────────────────────
  SECTION 01 — HERO
───────────────────────────────────────────── -->
<section class="hero">
  <div class="container">
    <div class="hero__grid">
      <div class="hero__content">
        <div class="tag fade-up fade-up-1">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
          Client Acquisition Intelligence
        </div>
        <h1 class="hero__headline fade-up fade-up-2">
          Your Intelligence Engine for <span class="hero__headline-accent">Client Acquisition</span>
        </h1>
        <p class="hero__sub fade-up fade-up-3">
          Flynt’s AI Agents remove the manual research layer behind client acquisition — allowing you to focus on conversations that close.
        </p>
        <div class="hero__ctas fade-up fade-up-4">
          <a href="https://tryflynt.ai/" class="btn btn--primary btn--lg">Get Started</a>
          <a href="#how-it-works" class="btn btn--outline btn--lg">See How Flynt Works →</a>
        </div>
        <p class="hero__social-proof fade-up fade-up-4">
          Trusted by Recruiters, Sales Teams and Agencies.
        </p>
      </div>
      <div class="hero__visual fade-up fade-up-3">
        <div class="hero__visual-glow"></div>
        <img
          src="/images/screenshots/run%20history%20zoomed.png"
          alt="Flynt Job Run History dashboard"
          class="hero__screenshot-img"
        />
      </div>
    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────
  SECTION 06 — STATS
───────────────────────────────────────────── -->
<section class="stats-bar">
  <div class="container">
    <div class="stats-badge" style="margin-bottom: 72px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      First leads in under 5 minutes
    </div>
    <div class="stats-grid">
      <div class="stat">
        <div class="stat__number">250+</div>
        <div class="stat__sublabel">AI Agents Running</div>
      </div>
      <div class="stat">
        <div class="stat__number">30 hrs</div>
        <div class="stat__sublabel">Saved Per User / Week</div>
      </div>
      <div class="stat">
        <div class="stat__number">3000+</div>
        <div class="stat__sublabel">Leads Delivered Daily</div>
      </div>
      <div class="stat">
        <div class="stat__number">100+</div>
        <div class="stat__sublabel">Teams Active</div>
      </div>
      <div class="stat">
        <div class="stat__number">600+</div>
        <div class="stat__sublabel">Markets Monitored</div>
      </div>
    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────
  SECTION 02 — BUILT FOR ONE PURPOSE (dark background)
───────────────────────────────────────────── -->
<section class="positioning">
  <div class="container">
    <p class="positioning__headline">
      <span class="positioning__headline-sub">Built for one purpose</span><br />
      <span style="color: #8B5CF6;">Winning new clients.</span>
    </p>
    <div class="positioning__grid">
      <div class="positioning__card">
        <span class="positioning__not">Not a database.</span>
        <p>A continuously running research system — not a static list you search once and rebuild every month.</p>
      </div>
      <div class="positioning__card">
        <span class="positioning__not">Not just a sender.</span>
        <p>Flynt leads with research and intelligence — so when outreach happens, it’s informed, targeted, and timely.</p>
      </div>
      <div class="positioning__card">
        <span class="positioning__not">Not another workflow to manage.</span>
        <p>Flynt is the intelligence layer beneath your stack. Set it up once — it runs, refines, and delivers without you.</p>
      </div>
    </div>

  </div>
</section>

<!-- ─────────────────────────────────────────────
  SECTION 03 — HOW IT WORKS (white background)
───────────────────────────────────────────── -->
<section class="section how-it-works" id="how-it-works">
  <div class="container">
    <div class="section-header section-header--center">
      <div class="tag"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>How It Works</div>
      <h2>Set it up once. Let it run.</h2>
    </div>
    <div class="steps">
      <div class="step">
        <div class="step__number">01</div>
        <h3>Define Your Targets</h3>
        <p>Industries, company size, job titles, geography. Flynt aligns to your criteria, not just keywords.</p>
      </div>
      <div class="step__connector"></div>
      <div class="step">
        <div class="step__number">02</div>
        <h3>Research Runs Automatically</h3>
        <p>AI agents work in the background. No list building, no spreadsheet juggling, no manual research sessions.</p>
      </div>
      <div class="step__connector"></div>
      <div class="step">
        <div class="step__number">03</div>
        <h3>Leads Land in Your Inbox</h3>
        <p>Every morning: names, titles, emails, and phone numbers — organised and ready to contact.</p>
      </div>
    </div>
  </div>
</section>



<!-- ─────────────────────────────────────────────
  SECTION 05 — WHO FLYNT IS BUILT FOR
───────────────────────────────────────────── -->
<section class="section built-for built-for--grey">
  <div class="container">
    <div class="section-header section-header--center">
      <div class="tag">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        Who It's For
      </div>
      <h2>Built for teams that <span class="audience__headline-accent">own revenue.</span></h2>
      <p>Designed for professionals whose success depends on winning new clients.</p>
    </div>

    <div class="audience-grid">
      <div class="audience-card">
        <div class="audience-card__icon">
          <svg width="38" height="38" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M16 11l2 2 4-4"/></svg>
        </div>
        <div class="audience-card__text">
          <h3>Recruiters & Recruitment Agencies</h3>
          <p>Find the companies that need your services — before your competition does.</p>
        </div>
      </div>

      <div class="audience-card">
        <div class="audience-card__icon">
          <svg width="38" height="38" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
        </div>
        <div class="audience-card__text">
          <h3>Sales & Go-to-Market Teams</h3>
          <p>The right accounts, at the right moment, with context — before every outreach.</p>
        </div>
      </div>

      <div class="audience-card">
        <div class="audience-card__icon">
          <svg width="38" height="38" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
        </div>
        <div class="audience-card__text">
          <h3>Agency Owners & Operators</h3>
          <p>Consistent client pipeline — without adding headcount or rebuilding lists.</p>
        </div>
      </div>

      <div class="audience-card">
        <div class="audience-card__icon">
          <svg width="38" height="38" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><rect x="2" y="7" width="20" height="14" rx="2"/><path stroke-linecap="round" stroke-linejoin="round" d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
        </div>
        <div class="audience-card__text">
          <h3>Revenue Leaders</h3>
          <p>Replace reactive prospecting with a system that runs whether your team is busy or not.</p>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ─────────────────────────────────────────────
  SECTION 07 — WHO FLYNT IS NOT FOR
───────────────────────────────────────────── -->
<section class="section not-for">
  <div class="container">
    <div class="not-for__layout">
      <div class="not-for__left">
        <h2>Flynt is not for <span class="not-for__accent">everyone.</span><br /></h2>
        <h3><span class="not-for__sub">That's intentional.</span></h3>
        <blockquote class="not-for__quote">
          Flynt prepares opportunity. You convert it.
        </blockquote>
      </div>
      <div class="not-for__right">
        <ul class="not-for__list">
          <li>
            <span class="not-for__icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </span>
            <span>Teams expecting guaranteed clients or instant results</span>
          </li>
          <li>
            <span class="not-for__icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </span>
            <span>Anyone who wants AI to replace judgment and sales skill</span>
          </li>
          <li>
            <span class="not-for__icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </span>
            <span>Users who won't follow up consistently</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ─────────────────────────────────────────────
  SECTION 10 — FINAL CTA
───────────────────────────────────────────── -->
<section class="final-cta">
  <div class="container">
    <div class="final-cta__inner">
      <h2>Stop researching.<br />Start closing.</h2>
      <p>Your next client is already in the market. Flynt finds them before someone else does.</p>
      <a href="https://tryflynt.ai/" class="btn btn--primary btn--lg">Get Started →</a>
      <span class="final-cta__disclaimer">No credit card required. Cancel anytime.</span>
    </div>
  </div>
</section>

</Layout>

<style>
/* ── Hero ── */
.hero {
  padding: 140px 0 120px;
  background: transparent;
  overflow: hidden;
}

.hero__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}

.hero__headline {
  font-size: 3rem;
  margin: 16px 0 28px;
  color: var(--black);
}

.hero__headline .hero__headline-accent {
  -webkit-text-stroke: 0.6px var(--purple);
}

.hero__headline-accent {
  color: var(--purple);
  display: block;
}

.hero__sub {
  font-size: 1.1rem;
  margin-bottom: 36px;
  color: var(--slate-600);
  line-height: 1.7;
}

.hero__ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}

.hero__social-proof {
  font-size: 0.875rem;
  color: var(--slate-500);
}

.hero__visual {
  position: relative;
}

.hero__visual-glow {
  position: absolute;
  inset: -24px;
  background: rgba(167, 139, 250, 0.35);
  border-radius: 28px;
  filter: blur(40px);
  z-index: 0;
  pointer-events: none;
}

.hero__screenshot-img {
  position: relative;
  z-index: 1;
  width: 100%;
  border-radius: 12px;
  box-shadow:
    0 2px 8px rgba(139, 92, 246, 0.08),
    0 12px 32px rgba(139, 92, 246, 0.14),
    0 40px 60px rgba(0, 0, 0, 0.18);
}

/* ── Positioning Strip ── */
.positioning {
  position: relative;
  background-color: #17072d;
  background-image: url('/images/backgrounds/World-Map.svg');
  background-size: 40%, cover;
  background-position: right top, bottom;
  background-repeat: no-repeat, no-repeat;
  padding: 200px 24px 112px;
  clip-path: polygon(0 120px, 100% 0, 100% 100%, 0 100%);
  margin-top: -120px;
  z-index: 1;
  overflow: hidden;
}

.positioning .container {
  display: flex;
  flex-direction: column;
  gap: 56px;
  position: relative;
  z-index: 2;
}

.positioning__headline {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -0.02em;
  line-height: 1.15;
  max-width: 640px;
  margin: 0;
}

.positioning__headline-sub {
  font-size: 0.5em;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.positioning__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.positioning__card {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: var(--radius-lg);
  padding: 32px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.positioning__not {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 700;
  color: rgb(215, 210, 225);

  display: block;
  margin-bottom: 14px;
}

.positioning__card p {
  font-size: 1.1rem;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.85);
}


/* ── What Flynt Does ── */
.what-flynt-does {
  padding: 160px 48px;
}
.what__tag-row {
  display: flex;
  justify-content: center;
  margin-bottom: 56px;
}

.what__tag {
  display: flex;
  align-items: center;
  gap: 6px;
}

.what__layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 72px;
  align-items: start;
}

.what__headline {
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 800;
  line-height: 1.3;
  letter-spacing: -0.03em;
  margin: 0 0 28px;
  color: var(--black);
  -webkit-text-stroke: 0.6px var(--black);
}

.what__headline-accent {
  color: var(--purple);
}

.what__clarity {
  margin: 0 0 24px;
  padding: 24px;
  background: var(--purple-bg);
  border-left: 4px solid var(--purple);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 1.125rem;
  font-weight: 500;
  color: var(--purple-900);
  line-height: 1.625;
}

.what__body {
  color: var(--slate-700);
  line-height: 1.7;
  margin-bottom: 16px;
}

.capability-card {
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-xl);
}

.capability-card__title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--slate-900);
  padding: 28px 28px 20px;
  margin: 0;
}

.capability-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 0 28px;
}

.capability-list li {
  display: flex;
  gap: 16px;
  color: var(--slate-700);
  align-items: flex-start;
  line-height: 1.55;
  padding: 20px 0;
  border-top: 1px solid var(--gray-100);
}

.capability-list li:first-child {
  border-top: none;
}

.capability-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--purple-bg-2);
  color: var(--purple);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}

.capability-card__footer {
  border-top: 1px solid var(--slate-200);
  padding: 20px 28px 24px;
  margin-top: 8px;
}

.what__closing {
  font-size: 0.875rem;
  color: var(--slate-500);
  font-style: italic;
  line-height: 1.65;
  margin: 0;
}

/* ── How It Works ── */
.steps {
  display: grid;
  grid-template-columns: 1fr auto 1fr auto 1fr;
  gap: 0;
  align-items: start;
}

.step {
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-lg);
  padding: 32px;
  box-shadow: var(--shadow-xl);
}

.step__number {
  font-family: var(--font-display);
  font-size: 2.5rem;
  font-weight: 800;
  color: var(--purple);
  opacity: 0.25;
  line-height: 1;
  margin-bottom: 16px;
}

.step h3 {
  margin-bottom: 12px;
  font-size: 1.3rem;
}

.step p {
  font-size: 1.05rem;
  color: var(--slate-600);
}

.step__connector {
  width: 40px;
  height: 1px;
  background: var(--slate-200);
  margin-top: 56px;
}

/* ── Built For grey background ── */
.built-for--grey {
  background-color: var(--slate-50);
  background-image:
    radial-gradient(ellipse at top left, rgba(124, 58, 237, 0.12) 0%, transparent 50%),
    radial-gradient(ellipse at bottom right, rgba(124, 58, 237, 0.12) 0%, transparent 50%),
    repeating-linear-gradient(
      45deg,
      rgba(124, 58, 237, 0.06) 0px,
      rgba(124, 58, 237, 0.06) 1px,
      transparent 1px,
      transparent 12px
    );
}

/* ── Stats Bar ── */
.stats-bar {
  background: linear-gradient(135deg, #4d269a 0%, #340e69 35%, #320D67 60%, #4f1fa2 100%);
  padding: 95px 24px 126px;
}

.stats-bar__headline {
  font-family: var(--font-display);
  font-size: clamp(1.1rem, 1.6vw, 1.25rem);
  font-weight: 500;
  color: rgba(255, 255, 255, 0.45);
  -webkit-text-stroke: 0;
  margin: 0 0 56px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  line-height: 1.4;
  max-width: 640px;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 0;
  margin: 0 0 40px;
}

.stat {
  padding: 0 40px 0 0;
}

.stat:first-child {
  padding-left: 0;
}

.stat__number {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 800;
  color: #dbb6f8;
  line-height: 1;
  margin-bottom: 12px;
  letter-spacing: -0.02em;
  border-left: 5px solid var(--purple);
  padding-left: 20px;
}

.stat__sublabel {
  font-size: 1.3uberem;
  font-weight: 650;
  color: rgb(215, 210, 225);
  margin-bottom: 6px;
  padding-left: 20px;
}

.stat__label {
  font-size: 1.075rem;
  font-style: italic;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.4;
  padding-left: 20px;
}

.stats-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.95);
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 8px 18px;
  border-radius: 100px;
}

.stats-badge svg {
  color: #a78bfa;
  flex-shrink: 0;
}

/* ── Audience ── */
.audience-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 32px;
}

.audience__headline-accent {
  color: var(--purple);
  -webkit-text-stroke: 0.6px var(--purple);
}

.audience-card {
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-lg);
  padding: 40px 32px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05), 0 1px 3px rgba(0,0,0,0.03);
  transition: background-color 0.2s, border-color 0.2s;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 28px;
}

.audience-card:hover {
  background-color: var(--purple-bg);
  border-color: var(--purple-bg-2);
}

.audience-card:hover .audience-card__icon {
  background: var(--purple);
  color: white;
}

.audience-card__icon {
  width: 96px;
  align-self: stretch;
  border-radius: var(--radius-md);
  background: var(--purple-bg-2);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--purple);
  flex-shrink: 0;
  transition: background 0.2s, color 0.2s;
}

.audience-card__text {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.audience-card h3 {
  font-size: 1.4rem;
  margin-bottom: 0;
  color: var(--slate-700);
  -webkit-text-stroke: 0.6px var(--slate-700);
}

.audience-card p {
