---
import Layout from '../../layouts/Layout.astro'
import { client } from '../../lib/sanity.js'

export async function getStaticPaths() {
  const posts = await client.fetch(`
    *[_type == "post" && !(_id in path("drafts.**"))] {
      slug,
      title,
      author,
      publishedAt,
      categories,
      excerpt,
      coverImage { alt, asset },
      body,
      seoTitle,
      seoDescription
    }
  `)

  return posts.map(post => ({
    params: { slug: post.slug.current },
    props: { post },
  }))
}

const { post } = Astro.props

function blocksToHtml(blocks = []) {
  return blocks.map(block => {
    if (block._type !== 'block' || !block.children) return ''
    const text = block.children.map(span => span.text).join('')
    switch (block.style) {
      case 'h1': return `<h1>${text}</h1>`
      case 'h2': return `<h2>${text}</h2>`
      case 'h3': return `<h3>${text}</h3>`
      case 'blockquote': return `<blockquote>${text}</blockquote>`
      default: return `<p>${text}</p>`
    }
  }).join('\n')
}

const bodyHtml = blocksToHtml(post.body)
const formattedDate = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : ''

const seoTitle = post.seoTitle || `${post.title} — Flynt Blog`
const seoDescription = post.seoDescription || post.excerpt || ''
---

<Layout title={seoTitle} description={seoDescription}>
  <article class="blog-post">
    <div class="container">
      <a href="/blog" class="back-link">← Back to Blog</a>
      <header class="post-header">
        {post.categories && post.categories.length > 0 && (
          <div class="post-categories">
            {post.categories.map(cat => <span class="post-category">{cat}</span>)}
          </div>
        )}
        {formattedDate && <p class="post-date">{formattedDate}{post.author && ` · ${post.author}`}</p>}
        <h1>{post.title}</h1>
        {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
      </header>
      <div class="post-body" set:html={bodyHtml} />
    </div>
  </article>
</Layout>

<style>
  .blog-post {
    padding: 60px 0 120px;
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--purple);
    text-decoration: none;
    margin-bottom: 40px;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .post-header {
    max-width: 720px;
    margin-bottom: 48px;
  }

  .post-categories {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .post-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--purple);
    background: var(--purple-bg);
    padding: 4px 10px;
    border-radius: 999px;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--slate-500);
    margin-bottom: 12px;
  }

  .post-header h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 16px;
    color: var(--slate-900);
  }

  .post-excerpt {
    font-size: 1.15rem;
    color: var(--slate-600);
    line-height: 1.6;
  }

  .post-body {
    max-width: 720px;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--slate-700);
  }

  .post-body h1,
  .post-body h2,
  .post-body h3 {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--slate-900);
    margin: 40px 0 16px;
  }

  .post-body h2 { font-size: 1.6rem; }
  .post-body h3 { font-size: 1.25rem; }

  .post-body p {
    margin-bottom: 20px;
  }

  .post-body blockquote {
    border-left: 4px solid var(--purple);
    padding-left: 20px;
    color: var(--slate-600);
    font-style: italic;
    margin: 32px 0;
  }
</style>
