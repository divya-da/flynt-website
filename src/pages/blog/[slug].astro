---
import Layout from '../../layouts/Layout.astro'
import { client } from '../../lib/sanity.js'
import { createImageUrlBuilder } from '@sanity/image-url'

const builder = createImageUrlBuilder(client)
function urlFor(source) {
  return builder.image(source)
}

export async function getStaticPaths() {
  const posts = await client.fetch(`
    *[_type == "post" && !(_id in path("drafts.**")) && defined(publishedAt) && publishedAt <= now()] {
      slug,
      title,
      author,
      authorBio,
      authorUrl,
      publishedAt,
      updatedAt,
      categories,
      excerpt,
      coverImage { alt, asset->{ url } },
      body[] {
        ...,
        _type == "image" => {
          ...,
          asset->{ url }
        }
      },
      seoTitle,
      seoDescription,
      seoTags
    }
  `)

  return posts.map(post => ({
    params: { slug: post.slug.current },
    props: { post },
  }))
}

const { post } = Astro.props

function blocksToHtml(blocks = []) {
  const html = []
  let i = 0

  while (i < blocks.length) {
    const block = blocks[i]

    if (block._type === 'image' && block.asset?.url) {
      const alt = block.alt || ''
      const caption = block.caption || ''
      html.push(`<figure class="post-image">
        <img src="${block.asset.url}" alt="${alt}" loading="lazy" />
        ${caption ? `<figcaption>${caption}</figcaption>` : ''}
      </figure>`)
      i++
      continue
    }

    if (block._type !== 'block' || !block.children) {
      i++
      continue
    }

    const text = block.children.map(span => {
      let t = span.text || ''
      if (span.marks?.includes('strong')) t = `<strong>${t}</strong>`
      if (span.marks?.includes('em')) t = `<em>${t}</em>`
      if (span.marks?.includes('code')) t = `<code>${t}</code>`
      return t
    }).join('')

    // Collect consecutive list items of the same type
    if (block.listItem === 'bullet' || block.listItem === 'number') {
      const tag = block.listItem === 'bullet' ? 'ul' : 'ol'
      const items = []
      while (i < blocks.length && blocks[i].listItem === block.listItem) {
        const itemText = blocks[i].children.map(span => {
          let t = span.text || ''
          if (span.marks?.includes('strong')) t = `<strong>${t}</strong>`
          if (span.marks?.includes('em')) t = `<em>${t}</em>`
          return t
        }).join('')
        items.push(`<li>${itemText}</li>`)
        i++
      }
      html.push(`<${tag}>${items.join('')}</${tag}>`)
      continue
    }

    switch (block.style) {
      case 'h1': html.push(`<h1>${text}</h1>`); break
      case 'h2': { const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-'); html.push(`<h2 id="${id}">${text}</h2>`); break }
      case 'h3': { const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-'); html.push(`<h3 id="${id}">${text}</h3>`); break }
      case 'h4': html.push(`<h4>${text}</h4>`); break
      case 'blockquote': html.push(`<blockquote>${text}</blockquote>`); break
      default: if (text.trim()) html.push(`<p>${text}</p>`)
    }
    i++
  }

  return html.join('\n')
}

function buildToc(blocks = []) {
  return (blocks || [])
    .filter(b => b._type === 'block' && b.style === 'h2')
    .map(b => {
      const text = b.children.map(s => s.text || '').join('')
      const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-')
      return { text, id }
    })
}

const bodyHtml = blocksToHtml(post.body)
const toc = buildToc(post.body)
const formattedDate = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : ''

const seoTitle = post.seoTitle || `${post.title} — Flynt Blog`
const seoDescription = post.seoDescription || post.excerpt || ''
const canonicalUrl = `https://tryflynt.ai/blog/${post.slug.current}`

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: seoDescription,
  url: canonicalUrl,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  author: {
    '@type': 'Person',
    name: post.author || 'Flynt',
    ...(post.authorUrl && { url: post.authorUrl }),
  },
  publisher: {
    '@type': 'Organization',
    name: 'Flynt',
    url: 'https://tryflynt.ai',
    logo: {
      '@type': 'ImageObject',
      url: 'https://tryflynt.ai/images/logo-with-text.svg',
    },
  },
  ...(post.coverImage?.asset?.url && { image: post.coverImage.asset.url }),
}
---

<Layout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  {post.seoTags && post.seoTags.length > 0 && (
    <meta name="keywords" content={post.seoTags.join(', ')} slot="head" />
  )}
  <article class="blog-post">
    <div class="container">
      <a href="/blog" class="back-link">← Back to Blog</a>
      <header class="post-header">
        {post.categories && post.categories.length > 0 && (
          <div class="post-categories">
            {post.categories.map(cat => <span class="post-category">{cat}</span>)}
          </div>
        )}
        {formattedDate && <p class="post-date">{formattedDate}{post.author && ` · ${post.author}`}</p>}
        <h1>{post.title}</h1>
        {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
      </header>

      {post.coverImage?.asset?.url && (
        <div class="post-cover">
          <img src={post.coverImage.asset.url} alt={post.coverImage.alt || post.title} loading="eager" />
        </div>
      )}

      <div class="post-layout">
        <aside class="post-sidebar">
          {toc.length > 1 && (
            <div class="sidebar-toc">
              <p class="sidebar-toc__title">In this article</p>
              <ul>
                {toc.map(item => (
                  <li>
                    <a href={`#${item.id}`}>{item.text}</a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          <div class="sidebar-cta">
            <p class="sidebar-cta__eyebrow">Client Acquisition on Autopilot</p>
            <p class="sidebar-cta__heading">Let AI Agents find your next client</p>
            <p class="sidebar-cta__body">Flynt monitors hiring signals 24/7 and surfaces the right companies before your competition does.</p>
            <a href="https://app.tryflynt.ai" class="btn btn--primary" style="background: var(--black); border-color: var(--black); box-shadow: none;" target="_blank" rel="noopener">Hire AI Agents Now</a>
          </div>
        </aside>

        <div class="post-body" set:html={bodyHtml} />
      </div>

      {post.authorBio && (
        <div class="author-bio">
          <p>
            {post.authorUrl
              ? <><strong><a href={post.authorUrl} target="_blank" rel="noopener">{post.author}</a></strong> — {post.authorBio}</>
              : <><strong>{post.author}</strong> — {post.authorBio}</>
            }
          </p>
        </div>
      )}
    </div>
  </article>
</Layout>

<style>
  .blog-post {
    padding: 60px 0 120px;
    background: var(--slate-50);
  }

  .blog-post .container {
    max-width: 1440px;
    background: white;
    border-radius: 16px;
    padding: 56px 64px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--purple);
    text-decoration: none;
    margin-bottom: 56px;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  /* ── Header ── */
  .post-header {
    max-width: 800px;
    margin: 0 auto 56px;
    text-align: center;
  }

  .post-categories {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 16px;
  }

  .post-category {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--purple);
    background: var(--purple-bg);
    padding: 4px 10px;
    border-radius: 999px;
  }

  .post-date {
    font-size: 0.85rem;
    color: var(--slate-500);
    margin-bottom: 32px;
  }

  .post-header h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 36px;
    color: var(--slate-900);
  }

  .post-excerpt {
    font-size: 1.1rem;
    color: var(--slate-600);
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .author-bio {
    font-size: 0.9rem;
    color: var(--slate-600);
    border-left: 3px solid var(--purple);
    padding-left: 14px;
    margin-top: 48px;
    line-height: 1.6;
  }

  .author-bio a {
    color: var(--purple);
    text-decoration: none;
  }

  .author-bio a:hover {
    text-decoration: underline;
  }

  /* ── Cover image ── */
  .post-cover {
    margin-bottom: 48px;
    border-radius: 12px;
    overflow: hidden;
  }

  .post-cover img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    display: block;
  }

  /* ── Two-column layout ── */
  .post-layout {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 64px;
    align-items: start;
  }

  /* ── Body ── */
  .post-body {
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--slate-700);
    min-width: 0;
  }

  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4) {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--slate-900);
    line-height: 1.25;
  }

  .post-body :global(h2) {
    font-size: 1.45rem;
    margin: 56px 0 18px;
  }

  .post-body :global(h3) {
    font-size: 1.2rem;
    margin: 40px 0 14px;
  }

  .post-body :global(h4) {
    font-size: 1.05rem;
    margin: 32px 0 12px;
  }

  .post-body :global(p) {
    margin-bottom: 14px;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 28px 0;
    padding-left: 44px;
  }

  .post-body :global(ul) { list-style-type: disc; }
  .post-body :global(ol) { list-style-type: decimal; }

  .post-body :global(li) {
    margin-bottom: 10px;
    padding-left: 4px;
    line-height: 1.75;
  }

  .post-body :global(blockquote) {
    border-left: 4px solid var(--purple);
    padding: 8px 0 8px 20px;
    color: var(--slate-600);
    font-style: italic;
    margin: 40px 0;
  }

  .post-body :global(code) {
    background: var(--slate-50);
    border: 1px solid var(--slate-200);
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 0.9em;
    font-family: monospace;
  }

  .post-body :global(strong) {
    font-weight: 700;
    color: var(--slate-900);
  }

  .post-body :global(.post-image) {
    margin: 32px 0;
  }

  .post-body :global(.post-image img) {
    width: 100%;
    border-radius: 8px;
    display: block;
  }

  .post-body :global(.post-image figcaption) {
    font-size: 0.85rem;
    color: var(--slate-500);
    text-align: center;
    margin-top: 8px;
  }

  /* ── Sidebar ── */
  .post-sidebar {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ── Table of Contents ── */
  .sidebar-toc {
    background: var(--slate-50);
    border-radius: 12px;
    padding: 20px 20px 16px;
  }

  .sidebar-toc__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--slate-500);
    margin-bottom: 12px;
  }

  .sidebar-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-toc li {
    margin: 0;
    padding: 0;
  }

  .sidebar-toc li a {
    display: block;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--slate-700);
    text-decoration: none;
    padding: 7px 0 7px 12px;
    border-left: 2px solid transparent;
    line-height: 1.45;
    transition: color 0.15s, border-color 0.15s;
  }

  .sidebar-toc li a:hover {
    color: var(--purple);
    border-left-color: var(--purple);
  }

  .sidebar-cta {
    background: var(--purple-bg);
    border-radius: 16px;
    padding: 28px 24px;
  }

  .sidebar-cta__eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--purple);
    margin-bottom: 10px;
  }

  .sidebar-cta__heading {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--slate-900);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .sidebar-cta__body {
    font-size: 0.9rem;
    color: var(--slate-600);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .sidebar-cta .btn {
    font-size: 1rem;
    padding: 10px 20px;
  }

  /* ── Mobile ── */
  @media (max-width: 860px) {
    .post-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .post-sidebar {
      position: static;
      order: 2;
    }

    .post-body {
      order: 1;
    }

    .post-header h1 {
      font-size: 2rem;
    }
  }
</style>
