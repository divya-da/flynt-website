---
import Layout from '../../layouts/Layout.astro'
import { client } from '../../lib/sanity.js'

const posts = await client.fetch(`
  *[_type == "post" && !(_id in path("drafts.**")) && defined(publishedAt) && publishedAt <= now()] | order(publishedAt desc) {
    title,
    slug,
    author,
    publishedAt,
    categories,
    excerpt,
    coverImage { alt, asset->{ url } }
  }
`)
---

<Layout title="Blog — Flynt" description="Insights on client acquisition, recruiting, and GTM strategy from the Flynt team.">
  <section class="blog-index">
    <div class="container">
      <div class="section-header">
        <h1>Blog</h1>
        <p>Insights on client acquisition, recruiting, and GTM strategy.</p>
      </div>
      <div class="post-grid">
        {posts.map(post => (
          <a href={`/blog/${post.slug.current}`} class="post-card">
            <div class="post-card__image">
              {post.coverImage?.asset?.url
                ? <img src={post.coverImage.asset.url} alt={post.coverImage.alt || post.title} loading="lazy" />
                : <div class="post-card__image-placeholder" />
              }
            </div>
            <div class="post-card__body">
              {post.categories && post.categories.length > 0 && (
                <div class="post-categories">
                  {post.categories.slice(0, 2).map(cat => <span class="post-category">{cat}</span>)}
                </div>
              )}
              <h2>{post.title}</h2>
              {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
              <div class="post-card__footer">
                <p class="post-meta">
                  {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : ''}
                  {post.author && ` · ${post.author}`}
                </p>
                <span class="post-link">Read more →</span>
              </div>
            </div>
          </a>
        ))}
        {posts.length === 0 && (
          <p class="no-posts">No posts yet. Check back soon.</p>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  .blog-index {
    padding: 80px 0 120px;
  }

  .blog-index h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .blog-index .section-header p {
    color: var(--slate-600);
    font-size: 1.1rem;
    margin-bottom: 60px;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 32px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--slate-200);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }

  .post-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
    border-color: var(--purple-200);
    transform: translateY(-2px);
  }

  /* Image */
  .post-card__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--slate-100);
  }

  .post-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }

  .post-card:hover .post-card__image img {
    transform: scale(1.03);
  }

  .post-card__image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--purple-bg) 0%, var(--slate-100) 100%);
  }

  /* Body */
  .post-card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 24px;
  }

  .post-categories {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }

  .post-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--purple);
    background: var(--purple-bg);
    padding: 3px 8px;
    border-radius: 999px;
  }

  .post-card h2 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--slate-900);
    line-height: 1.35;
  }

  .post-excerpt {
    font-size: 0.9rem;
    color: var(--slate-600);
    line-height: 1.6;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--slate-100);
  }

  .post-meta {
    font-size: 0.8rem;
    color: var(--slate-500);
  }

  .post-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--purple);
  }

  .no-posts {
    color: var(--slate-500);
    font-size: 1rem;
  }
</style>
