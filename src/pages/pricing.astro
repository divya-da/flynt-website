---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Pricing — Flynt AI"
  description="Three plans built for where you are and where you're going. Every tier includes Flynt's core intelligence system."
>

<div class="pricing-page">

  <!-- Header -->
  <section class="page-hero">
    <div class="container">
      <div class="tag">Pricing</div>
      <h1>Intelligence at every stage.</h1>
      <p>Three plans. Every tier includes Flynt's core intelligence system. Upgrade as your operation scales.</p>
    </div>
  </section>

  <!-- Cards -->
  <section class="section pricing-section">
    <div class="container">
      <div class="pricing-grid">

        <!-- Starter -->
        <div class="plan">
          <div class="plan__header">
            <h3>Starter</h3>
            <p class="plan__tagline">For solo operators getting started.</p>
            <div class="plan__price">
              <span class="plan__amount">$149</span>
              <span class="plan__period">/mo</span>
            </div>
            <a href="https://tryflynt.ai/" class="btn btn--outline plan__cta">Start with Starter</a>
          </div>
          <div class="plan__features-label">What's Included</div>
          <ul class="plan__features">
            <li><span class="check">✓</span> 1 AI agent included</li>
            <li><span class="check">✓</span> Core research & lead delivery</li>
            <li><span class="check">✓</span> Decision-maker identification</li>
            <li><span class="check">✓</span> Auto Data Enrichment</li>
            <li><span class="check">✓</span> Email support</li>
          </ul>
        </div>

        <!-- Pro (highlighted) -->
        <div class="plan plan--featured">
          <div class="plan__badge">Most Popular</div>
          <div class="plan__header">
            <h3>Pro</h3>
            <p class="plan__tagline">For active operators running outbound.</p>
            <div class="plan__price">
              <span class="plan__amount">$297</span>
              <span class="plan__period">/mo</span>
            </div>
            <a href="https://tryflynt.ai/" class="btn btn--primary plan__cta">Start with Pro</a>
          </div>
          <div class="plan__features-label">What's Included</div>
          <ul class="plan__features">
            <li><span class="check">✓</span> Everything in Starter</li>
            <li><span class="check">✓</span> 2 AI agents included</li>
            <li><span class="check">✓</span> Advanced AI filtering & targeting</li>
            <li><span class="check">✓</span> Industry Targeting</li>
            <li><span class="check">✓</span> Option to add an extra agent</li>
            <li><span class="check">✓</span> Email support</li>
          </ul>
        </div>

        <!-- Growth -->
        <div class="plan">
          <div class="plan__header">
            <h3>Growth</h3>
            <p class="plan__tagline">For teams who need scale and speed.</p>
            <div class="plan__price">
              <span class="plan__amount">$529</span>
              <span class="plan__period">/mo</span>
            </div>
            <a href="https://tryflynt.ai/" class="btn btn--outline plan__cta">Start with Growth</a>
          </div>
          <div class="plan__features-label">What's Included</div>
          <ul class="plan__features">
            <li><span class="check">✓</span> Everything in Pro</li>
            <li><span class="check">✓</span> 4 AI agents included</li>
            <li><span class="check">✓</span> Purchase up to 4 extra agents</li>
            <li><span class="check">✓</span> Priority support & dedicated onboarding</li>
          </ul>
        </div>

      </div>

      <p class="pricing-disclaimer">
        Pricing reflects time saved and consistency gained — not guaranteed outcomes. Flynt prepares opportunity. Results depend on your execution.
      </p>

      <div class="enterprise-block">
        <div class="enterprise-block__inner">
          <div>
            <h3>Running a larger team?</h3>
            <p>Contact us for custom pricing.</p>
          </div>
          <a href="mailto:info@tryflynt.ai" class="btn btn--outline">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Tier Comparison Table -->
  <section class="section comparison-section">
    <div class="container">
      <div class="section-header section-header--center">
        <h2>What's included at each level.</h2>
      </div>
      <div class="table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th class="compare-table__feature">Feature</th>
              <th>Starter<br /><span class="th-price">$149/mo</span></th>
              <th class="compare-table__featured">Pro<br /><span class="th-price">$297/mo</span></th>
              <th>Growth<br /><span class="th-price">$529/mo</span></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>AI Agents Included</td>
              <td>1</td>
              <td class="compare-table__featured">2</td>
              <td>4</td>
            </tr>
            <tr>
              <td>Active Hiring Signal Detection</td>
              <td><span class="t-check">✓</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Decision-Maker Identification</td>
              <td><span class="t-check">✓</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Auto Dara Enrichment</td>
              <td><span class="t-check">✓</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Daily Lead Delivery</td>
              <td><span class="t-check">✓</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Advanced AI Targeting</td>
              <td><span class="t-dash">—</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Industry Targeting</td>
              <td><span class="t-dash">—</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Add Extra Agents</td>
              <td><span class="t-dash">—</span></td>
              <td class="compare-table__featured">1 Add-on</td>
              <td>4 Add-ons</td>
            </tr>
            <tr>
              <td>Priority Support</td>
              <td><span class="t-dash">—</span></td>
              <td class="compare-table__featured"><span class="t-dash">—</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Flynt vs Competitors -->
  <section class="section competitor-section">
    <div class="container">
      <div class="section-header section-header--center">
        <h2>Why teams switch to Flynt.</h2>
        <p>Most tools give you data, outreach, or workflows. Flynt gives you a complete, automated research system — ready to run from day one.</p>
      </div>
      <div class="table-wrap">
        <table class="compare-table compare-table--competitors">
          <thead>
            <tr>
              <th class="compare-table__feature"></th>
              <th class="compare-table__featured">Flynt</th>
              <th>Clay</th>
              <th>Apollo</th>
              <th>Instantly</th>
              <th>LLMs</th>
              <th>Open Claw</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Starting Price</td>
              <td class="compare-table__featured">$149/mo</td>
              <td>$300+/mo</td>
              <td>$110/mo</td>
              <td>$97/mo</td>
              <td>Free+</td>
              <td>Varies</td>
            </tr>
            <tr>
              <td>Built for Client Acquisition</td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-dash">—</span></td>
              <td>Partial</td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
            </tr>
            <tr>
              <td>Automated Daily Leads</td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
            </tr>
            <tr>
              <td>Runs Without Manual Setup</td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-dash">—</span></td>
              <td>Partial</td>
              <td>Partial</td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
            </tr>
            <tr>
              <td>AI Agents Included</td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
            </tr>
            <tr>
              <td>Complexity</td>
              <td class="compare-table__featured">Low</td>
              <td>High</td>
              <td>Medium</td>
              <td>Medium</td>
              <td>High</td>
              <td>High</td>
            </tr>
            <tr>
              <td>Time Saved</td>
              <td class="compare-table__featured">High</td>
              <td>Medium</td>
              <td>Low</td>
              <td>Low</td>
              <td>Low</td>
              <td>Low</td>
            </tr>
            <tr>
              <td>No Technical Skill Required</td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-dash">—</span></td>
              <td>Partial</td>
              <td>Partial</td>
              <td><span class="t-dash">—</span></td>
              <td><span class="t-dash">—</span></td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="table-footnote">* Complexity and time saved ratings are relative estimates based on typical use cases. Pricing reflects published starting tiers as of 2026.</p>
    </div>
  </section>

</div>

</Layout>

<style>
.page-hero {
  padding: 72px 24px 64px;
  text-align: center;
  background: var(--white);
}

.page-hero h1 {
  margin: 12px 0 16px;
}

.page-hero p {
  font-size: 1.05rem;
  max-width: 560px;
  margin: 0 auto;
  color: var(--slate-600);
}

.pricing-section {
  background: var(--slate-50);
  padding-top: 0;
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  align-items: start;
  margin-bottom: 32px;
}

.plan {
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-lg);
  padding: 32px;
  position: relative;
}

.plan--featured {
  border-color: var(--purple);
  box-shadow: var(--shadow-purple);
  transform: translateY(-8px);
}

.plan__badge {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--purple);
  color: white;
  font-family: var(--font-display);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: 100px;
  white-space: nowrap;
}

.plan__header {
  margin-bottom: 24px;
}

.plan__header h3 {
  margin-bottom: 6px;
}

.plan__tagline {
  font-size: 0.88rem;
  color: var(--slate-500);
  margin-bottom: 20px;
}

.plan__price {
  display: flex;
  align-items: baseline;
  gap: 4px;
  margin-bottom: 20px;
}

.plan__amount {
  font-family: var(--font-display);
  font-size: 2.8rem;
  font-weight: 800;
  color: var(--black);
}

.plan__period {
  font-size: 1rem;
  color: var(--slate-500);
}

.plan--featured .plan__amount {
  color: var(--purple);
}

.plan__cta {
  width: 100%;
  justify-content: center;
}

.plan__features-label {
  font-family: var(--font-display);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--slate-400);
  margin-bottom: 14px;
  padding-top: 24px;
  border-top: 1px solid var(--slate-100);
}

.plan__features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.plan__features li {
  display: flex;
  gap: 10px;
  font-size: 0.9rem;
  color: var(--slate-700);
  align-items: flex-start;
}

.check {
  color: var(--purple);
  font-weight: 700;
  flex-shrink: 0;
}

.pricing-disclaimer {
  text-align: center;
  font-size: 0.875rem;
  color: var(--slate-500);
  max-width: 600px;
  margin: 0 auto 40px;
  font-style: italic;
}

.enterprise-block {
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-lg);
  padding: 28px 32px;
}

.enterprise-block__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.enterprise-block h3 {
  font-size: 1.05rem;
  margin-bottom: 6px;
}

.enterprise-block p {
  font-size: 0.9rem;
  color: var(--slate-600);
}

/* ── Comparison Tables ── */
.comparison-section {
  background: var(--white);
}

.competitor-section {
  background: var(--slate-50);
}

.table-wrap {
  overflow-x: auto;
  border-radius: var(--radius-lg);
  border: 1px solid var(--slate-200);
  margin-top: 40px;
}

.compare-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.925rem;
}

.compare-table thead tr {
  background: #1e1340;
}

.compare-table thead th {
  padding: 16px 20px;
  color: rgba(255,255,255,0.7);
  font-weight: 700;
  font-size: 0.95rem;
  text-align: center;
}

.compare-table thead th.compare-table__feature {
  text-align: center;
  color: rgba(255,255,255,0.5);
}

.compare-table thead th.compare-table__featured {
  background: var(--purple);
  color: #ffffff;
}

.th-price {
  display: block;
  font-size: 0.75rem;
  font-weight: 400;
  opacity: 0.8;
  margin-top: 2px;
}

.compare-table tbody tr {
  border-bottom: 1px solid var(--slate-100);
}

.compare-table tbody tr:last-child {
  border-bottom: none;
}

.compare-table tbody tr:nth-child(even) {
  background: var(--slate-50);
}

.compare-table--competitors tbody tr:nth-child(even) {
  background: rgba(0,0,0,0.02);
}

.compare-table tbody td {
  padding: 14px 20px;
  text-align: center;
  color: var(--slate-700);
}

.compare-table tbody td.compare-table__feature {
  text-align: left;
  font-weight: 500;
  color: var(--slate-800);
}

.compare-table tbody td.compare-table__featured {
  background: rgba(124, 58, 237, 0.05);
  font-weight: 600;
  color: var(--slate-800);
  border-left: 1px solid rgba(124,58,237,0.15);
  border-right: 1px solid rgba(124,58,237,0.15);
}

.t-check {
  color: var(--purple);
  font-weight: 700;
  font-size: 1rem;
}

.t-dash {
  color: var(--slate-300);
}

.table-footnote {
  font-size: 0.8rem;
  color: var(--slate-400);
  margin-top: 16px;
  font-style: italic;
}

@media (max-width: 900px) {
  .pricing-grid { grid-template-columns: 1fr; }
  .plan--featured { transform: none; }
  .enterprise-block__inner { flex-direction: column; align-items: flex-start; }
}
</style>
