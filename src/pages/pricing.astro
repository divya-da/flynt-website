<script>
  function setBilling(type) {
    const isMonthly = type === 'monthly';

    document.getElementById('toggle-monthly').classList.toggle('toggle-btn--active', isMonthly);
    document.getElementById('toggle-annual').classList.toggle('toggle-btn--active', !isMonthly);

    // Update all price amount elements with data-monthly / data-annual
    document.querySelectorAll('.plan__annual-only[data-monthly][data-annual]').forEach(el => {
      el.textContent = isMonthly ? el.dataset.monthly : el.dataset.annual;
    });

    // Update comparison table th-price elements
    document.querySelectorAll('.th-price[data-monthly][data-annual]').forEach(el => {
      el.textContent = isMonthly ? el.dataset.monthly : el.dataset.annual;
    });

    // Update competitor table starting price cell
    document.querySelectorAll('[data-monthly][data-annual]:not(.plan__annual-only):not(.th-price)').forEach(el => {
      el.textContent = isMonthly ? el.dataset.monthly : el.dataset.annual;
    });

    // Show/hide annual billing info blocks
    document.querySelectorAll('.plan__annual-info').forEach(el => {
      (el as HTMLElement).style.display = isMonthly ? 'none' : 'block';
    });

    // Show/hide monthly annual teasers
    document.querySelectorAll('.plan__annual-teaser').forEach(el => {
      (el as HTMLElement).style.display = isMonthly ? 'block' : 'none';
    });
  }

  function toggleTip(el) {
    const isOpen = el.classList.contains('tip--open');
    // Close any other open tips
    document.querySelectorAll('.plan__info-btn.tip--open').forEach(b => b.classList.remove('tip--open'));
    if (!isOpen) el.classList.add('tip--open');
  }

  // Close tip when clicking outside
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.plan__info-btn')) {
      document.querySelectorAll('.plan__info-btn.tip--open').forEach(b => b.classList.remove('tip--open'));
    }
  });

  // Expose globally for onclick handlers
  (window as any).setBilling = setBilling;
  (window as any).toggleTip = toggleTip;
</script>

