---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Pricing — Flynt AI"
  description="Three plans built for where you are and where you're going. Every tier includes Flynt's core intelligence system."
>

<div class="pricing-page">

  <!-- Header -->
  <section class="page-hero">
    <div class="container">
      <div class="tag">Pricing</div>
      <h1><span class="accent">AI agents</span> for every stage.</h1>
      <p>Four plans. Every tier includes Flynt's core intelligence system.</br>Upgrade as your operation scales.</p>
    </div>
  </section>

  <!-- Cards -->
  <section class="section pricing-section">
    <div class="container">

      <!-- Billing Toggle -->
      <div class="billing-toggle">
        <button class="toggle-btn" id="toggle-monthly" onclick="setBilling('monthly')">Monthly</button>
        <button class="toggle-btn toggle-btn--active" id="toggle-annual" onclick="setBilling('annual')">
          Annual <span class="toggle-badge">Save up to $998/yr</span>
        </button>
      </div>

      <div class="pricing-grid">

        <!-- Free -->
        <div class="plan">
          <div class="plan__header">
            <h3>Free</h3>
            <p class="plan__tagline">Try Flynt at no cost.</p>
            <div class="plan__price">
              <span class="plan__dollar">$</span><span class="plan__amount plan__amount--free">0</span>
              <span class="plan__period">/mo</span>
            </div>
            <a href="https://app.tryflynt.ai/" class="btn btn--outline plan__cta">Get Started Free</a>
            <p class="plan__sub-cta">No credit card required</p>
          </div>
          <div class="plan__features-label">What's Included</div>
          <ul class="plan__features">
            <li><span class="check">✓</span> 1 AI Agent</li>
            <li><span class="check">✓</span> Up to 30 leads</li>
            <li><span class="check">✓</span> Core Research</li>
            <li><span class="check">✓</span> Decision-maker Identification</li>
            <li><span class="check">✓</span> Auto Data Enrichment</li>
          </ul>
        </div>

        <!-- Starter -->
        <div class="plan">
          <div class="plan__header">
            <h3>Starter</h3>
            <p class="plan__tagline">For solo operators getting started.</p>
            <div class="plan__price">
              <span class="plan__dollar">$</span><span class="plan__amount plan__annual-only" data-monthly="139" data-annual="116">116</span>
              <span class="plan__period">/mo</span>
            </div>
            <div class="plan__annual-teaser">Switch to annual — save $278/yr</div>
            <div class="plan__annual-info">
              <div class="plan__billing-row">
                <span class="plan__billed-inline">Billed $1,390/yr</span>
                <span class="plan__free-badge">save $278</span>
                <span class="plan__info-btn plan__has-tip" tabindex="0" onclick="toggleTip(this)">
