---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Pricing — Flynt AI"
  description="Three plans built for where you are and where you're going. Every tier includes Flynt's core intelligence system."
>

<div class="pricing-page">

  <!-- Header -->
  <section class="page-hero">
    <div class="container">
      <div class="tag">Pricing</div>
      <h1><span class="accent">AI agents</span> for every stage.</h1>
      <p>Four plans. Every tier includes Flynt's core intelligence system.</br>Upgrade as your operation scales.</p>
    </div>
  </section>

  <!-- Cards -->
  <section class="section pricing-section">
    <div class="container">
      <div class="pricing-grid">

        <!-- Starter -->
        <div class="plan">
          <div class="plan__header">
            <h3>Starter</h3>
            <p class="plan__tagline">For solo operators getting started.</p>
            <div class="plan__price">
              <span class="plan__amount">$139</span>
              <span class="plan__period">/mo</span>
            </div>
            <a href="https://app.tryflynt.ai/" class="btn btn--outline plan__cta">Start with Starter</a>
          </div>
          <div class="plan__features-label">What's Included</div>
          <ul class="plan__features">
            <li><span class="check">✓</span> 1 AI Agent</li>
            <li><span class="check">✓</span> Up to 30 leads delivered daily 24/7</li>
            <li><span class="check">✓</span> Core Research & Lead Delivery</li>
            <li><span class="check">✓</span> Decision-maker Identification</li>
            <li><span class="check">✓</span> Auto Data Enrichment</li>
            <li><span class="check">✓</span> Basic Support</li>
          </ul>
        </div>

        <!-- Pro (highlighted) -->
        <div class="plan plan--featured">
          <div class="plan__badge">Most Popular</div>
          <div class="plan__header">
            <h3>Pro</h3>
            <p class="plan__tagline">For active operators running outbound.</p>
            <div class="plan__price">
              <span class="plan__amount">$267</span>
              <span class="plan__period">/mo</span>
            </div>
            <a href="https://app.tryflynt.ai/" class="btn btn--primary plan__cta">Start with Pro</a>
          </div>
          <div class="plan__features-label">What's Included</div>
          <ul class="plan__features">
            <li><span class="check">✓</span> Everything in Starter</li>
            <li><span class="check">✓</span> 2 AI Agents</li>
            <li><span class="check">✓</span> Up to 60 leads delivered daily 24/7</li>
            <li><span class="check">✓</span> Advanced AI Filtering & Targeting</li>
            <li><span class="check">✓</span> Industry Targeting</li>
            <li><span class="check">✓</span> Option to purchase 1 Extra Agent</li>
            <li><span class="check">✓</span> Basic Support</li>
          </ul>
        </div>

        <!-- Growth -->
        <div class="plan">
          <div class="plan__header">
            <h3>Growth</h3>
            <p class="plan__tagline">For teams who need scale and speed.</p>
            <div class="plan__price">
              <span class="plan__amount">$499</span>
              <span class="plan__period">/mo</span>
            </div>
            <a href="https://app.tryflynt.ai/" class="btn btn--outline plan__cta">Start with Growth</a>
          </div>
          <div class="plan__features-label">What's Included</div>
          <ul class="plan__features">
            <li><span class="check">✓</span> Everything in Pro</li>
            <li><span class="check">✓</span> 4 AI Agents</li>
            <li><span class="check">✓</span> Up to 120 leads delivered daily 24/7</li>
            <li><span class="check">✓</span> Option to purchase up to 4 Extra Agents</li>
            <li><span class="check">✓</span> Priority Support</li>
          </ul>
        </div>

        <!-- Scale -->
        <div class="plan plan--scale">
          <div class="plan__header">
            <h3>Scale</h3>
            <p class="plan__tagline">For agencies and high-volume operations.</p>
            <div class="plan__price plan__price--contact">
              <span class="plan__contact">Contact Sales</span>
            </div>
            <a href="mailto:info@tryflynt.ai" class="btn btn--outline plan__cta">Get in Touch</a>
          </div>
          <div class="plan__features-label">What's Included</div>
          <ul class="plan__features">
            <li><span class="check">✓</span> Everything in Growth</li>
            <li><span class="check">✓</span> Unlimited AI Agents</li>
            <li><span class="check">✓</span> Unlimited leads per day</li>
            <li><span class="check">✓</span> Priority Support</li>
            <li><span class="check">✓</span> Dedicated Onboarding</li>
          </ul>
        </div>

      </div>

      <p class="pricing-disclaimer">
        Pricing reflects time saved and consistency gained — not guaranteed outcomes.</br>Flynt prepares opportunity. Results depend on your execution.
      </p>

    </div>
  </section>

  <!-- Tier Comparison Table -->
  <section class="section comparison-section">
    <div class="container">
      <div class="section-header section-header--center">
        <h2>What's <span class="accent-word">included</span> at each level.</h2>
      </div>
      <div class="table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th class="compare-table__feature"></th>
              <th>Starter<br /><span class="th-price">$139/mo</span></th>
              <th class="compare-table__featured">Pro<br /><span class="th-price">$267/mo</span></th>
              <th>Growth<br /><span class="th-price">$499/mo</span></th>
              <th>Scale<br /><span class="th-price">Contact Sales</span></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>AI Agents Included</td>
              <td>1</td>
              <td class="compare-table__featured">2</td>
              <td>4</td>
              <td>Unlimited</td>
            </tr>
            <tr>
              <td>Max Leads Per Day</td>
              <td>30</td>
              <td class="compare-table__featured">60</td>
              <td>120</td>
              <td>Unlimited</td>
            </tr>
            <tr>
              <td>Active Hiring Signal Detection</td>
              <td><span class="t-check">✓</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Decision-Maker Identification</td>
              <td><span class="t-check">✓</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Auto Data Enrichment</td>
              <td><span class="t-check">✓</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Daily Lead Delivery</td>
              <td><span class="t-check">✓</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Advanced AI Targeting</td>
              <td><span class="t-dash">✕</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Industry Targeting</td>
              <td><span class="t-dash">✕</span></td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Add Extra Agents</td>
              <td><span class="t-dash">✕</span></td>
              <td class="compare-table__featured">1 Add-on</td>
              <td>4 Add-ons</td>
              <td>Unlimited</td>
            </tr>
            <tr>
              <td>Priority Support</td>
              <td><span class="t-dash">✕</span></td>
              <td class="compare-table__featured"><span class="t-dash">✕</span></td>
              <td><span class="t-check">✓</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
            <tr>
              <td>Dedicated Onboarding</td>
              <td><span class="t-dash">✕</span></td>
              <td class="compare-table__featured"><span class="t-dash">✕</span></td>
              <td><span class="t-dash">✕</span></td>
              <td><span class="t-check">✓</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Flynt vs Competitors -->
  <section class="section competitor-section">
    <div class="container">
      <div class="section-header section-header--center">
        <h2>Why teams <span class="accent-word">switch</span> to Flynt.</h2>
        <p>Most tools give you data, outreach, or workflows. Flynt gives you a complete, automated research system — ready to run from day one.</p>
      </div>
      <div class="table-wrap">
        <table class="compare-table compare-table--competitors">
          <thead>
            <tr>
              <th class="compare-table__feature"></th>
              <th class="compare-table__featured">Flynt</th>
              <th>ZoomInfo</th>
              <th>Clay</th>
              <th>Apollo</th>
              <th>Instantly</th>
              <th>LLMs</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Starting Price*</td>
              <td class="compare-table__featured">$139/mo</td>
              <td>$1,000+/mo</td>
              <td>$149–$800/mo</td>
              <td>$150–$400/mo</td>
              <td>$150–$400/mo</td>
              <td>$0–$20/mo</td>
            </tr>
            <tr>
              <td>Built for Client Acquisition</td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td>Partial</td>
              <td>Partial</td>
              <td>Partial</td>
              <td><span class="t-dash">✕</span></td>
              <td><span class="t-dash">✕</span></td>
            </tr>
            <tr>
              <td>Automated Daily Leads</td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-dash">✕</span></td>
              <td>Partial</td>
              <td><span class="t-dash">✕</span></td>
              <td><span class="t-dash">✕</span></td>
              <td><span class="t-dash">✕</span></td>
            </tr>
            <tr>
              <td>Setup Time</td>
              <td class="compare-table__featured">~5 min</td>
              <td>Days–weeks</td>
              <td>20–40 hrs</td>
              <td>Days–weeks</td>
              <td>Days of config</td>
              <td>Always manual</td>
            </tr>
            <tr>
              <td>AI Agents Included</td>
              <td class="compare-table__featured"><span class="t-check">✓</span></td>
              <td><span class="t-dash">✕</span></td>
              <td>Partial</td>
              <td><span class="t-dash">✕</span></td>
              <td><span class="t-dash">✕</span></td>
              <td><span class="t-dash">✕</span></td>
            </tr>
            <tr>
              <td>Complexity</td>
              <td class="compare-table__featured">Low</td>
              <td>High</td>
              <td>High</td>
              <td>Medium</td>
              <td>Medium</td>
              <td>High</td>
            </tr>
            <tr>
              <td>Time Saved</td>
              <td class="compare-table__featured">High</td>
              <td>Low</td>
              <td>Medium</td>
              <td>Low</td>
              <td>Low</td>
              <td>Low</td>
            </tr>
            <tr>
              <td>Technical Skill Required</td>
              <td class="compare-table__featured"><span class="t-check">No</span></td>
              <td>Partial</td>
              <td>Yes</td>
              <td>Partial</td>
              <td>Partial</td>
              <td>No</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="table-footnote"><em>* Competitor pricing reflects estimated real-world total cost including credits, add-ons, and required tooling. Published starting prices vary.</em></p>
    </div>
  </section>

</div>

</Layout>

<style>
.page-hero {
  padding: 72px 24px 64px;
  text-align: center;
  background: var(--white);
}

.page-hero h1 {
  margin: 12px 0 16px;
  font-size: 3rem;
}

.accent {
  color: var(--purple);
  -webkit-text-stroke: 0.6px var(--purple);
}

.accent-word {
  color: var(--purple);
  -webkit-text-stroke: 0;
}

.page-hero p {
  font-size: 1.05rem;
  max-width: 560px;
  margin: 0 auto;
  color: var(--slate-600);
}

.pricing-section {
  background: var(--slate-50);
  padding-top: 0;
}

.pricing-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  align-items: stretch;
  margin-bottom: 32px;
}

.plan {
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-lg);
  padding: 32px;
  position: relative;
}

.plan--featured {
  border-color: var(--purple);
  box-shadow: var(--shadow-purple);
  transform: translateY(-8px);
}

.plan__badge {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--purple);
  color: white;
  font-family: var(--font-display);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: 100px;
  white-space: nowrap;
}

.plan__header {
  margin-bottom: 24px;
}

.plan__header h3 {
  margin-bottom: 6px;
}

.plan__tagline {
  font-size: 0.88rem;
  color: var(--slate-500);
  margin-bottom: 20px;
}

.plan__price {
  display: flex;
  align-items: baseline;
  gap: 4px;
  margin-bottom: 20px;
}

.plan__amount {
  font-family: var(--font-display);
  font-size: 2.8rem;
  font-weight: 800;
  color: var(--black);
}

.plan__period {
  font-size: 1rem;
  color: var(--slate-500);
}

.plan--featured .plan__amount {
  color: var(--purple);
}

.plan__price--contact {
  margin-bottom: 20px;
}

.plan__contact {
  font-family: var(--font-display);
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--slate-700);
}

.plan__cta {
  width: 100%;
  justify-content: center;
}

.plan__features-label {
  font-family: var(--font-display);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--slate-400);
  margin-bottom: 14px;
  padding-top: 24px;
  border-top: 1px solid var(--slate-100);
}

.plan__features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.plan__features li {
  display: flex;
  gap: 10px;
  font-size: 0.9rem;
  color: var(--slate-700);
  align-items: flex-start;
}

.check {
  color: var(--purple);
  font-weight: 700;
  flex-shrink: 0;
}

.pricing-disclaimer {
  text-align: center;
  font-size: 0.875rem;
  color: var(--slate-500);
  max-width: 600px;
  margin: 0 auto 0px;
  font-style: italic;
}

.enterprise-block {
  background: var(--white);
  border: 1px solid var(--slate-200);
  border-radius: var(--radius-lg);
  padding: 28px 32px;
}

.enterprise-block__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.enterprise-block h3 {
  font-size: 1.05rem;
  margin-bottom: 6px;
}

.enterprise-block p {
  font-size: 0.9rem;
  color: var(--slate-600);
}

/* ── Comparison Tables ── */
.comparison-section {
  background: var(--white);
}

.competitor-section {
  background: var(--slate-50);
}

.table-wrap {
  overflow-x: auto;
  border-radius: var(--radius-lg);
  border: 1px solid var(--slate-200);
  margin-top: 40px;
}

.compare-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 1rem;
}

.compare-table thead tr {
  background: #1e1340;
}

.compare-table thead th {
  padding: 16px 20px;
  color: rgba(255,255,255,0.95);
  font-weight: 700;
  font-size: 1.2rem;
  text-align: center;
}

.compare-table thead th.compare-table__feature {
  text-align: center;
  color: rgba(255,255,255,0.7);
}

.compare-table thead th.compare-table__featured {
  background: var(--purple);
  color: #ffffff;
}

.th-price {
  display: block;
  font-size: 0.85rem;
  font-weight: 400;
  font-style: italic;
  opacity: 0.8;
  margin-top: 2px;
}

.compare-table tbody tr {
  border-bottom: 1px solid var(--slate-100);
}

.compare-table tbody tr:last-child {
  border-bottom: none;
}

.compare-table tbody tr:nth-child(even) {
  background: var(--slate-50);
}

.compare-table--competitors tbody tr:nth-child(even) {
  background: rgba(0,0,0,0.02);
}

.compare-table tbody td {
  padding: 14px 20px;
  text-align: center;
  color: var(--slate-700);
}

.compare-table tbody td.compare-table__feature {
  text-align: left;
  font-weight: 500;
  color: var(--slate-800);
}

.compare-table tbody td.compare-table__featured {
  background: rgba(124, 58, 237, 0.05);
  font-weight: 700;
  color: var(--purple);
  border-left: 1px solid rgba(124,58,237,0.15);
  border-right: 1px solid rgba(124,58,237,0.15);
}

.t-check {
  color: var(--purple);
  font-weight: 700;
  font-size: 1.1rem;
}

.t-dash {
  color: #ef4444;
  font-weight: 700;
  font-size: 1rem;
}

.table-footnote {
  font-size: 0.8rem;
  color: var(--slate-400);
  margin-top: 16px;
  font-style: italic;
}

@media (max-width: 1100px) {
  .pricing-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 900px) {
  .pricing-grid { grid-template-columns: 1fr; }
  .plan--featured { transform: none; }
  .enterprise-block__inner { flex-direction: column; align-items: flex-start; }
}
</style>
